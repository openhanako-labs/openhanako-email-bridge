# email-monitor 环境变量配置
# 复制为 .env 并填入实际值后重启服务
# pm2 restart email-monitor --update-env

# ── ClawEmail 配置 ────────────────────────────
# API Key（必填）
CLAWEMAIL_API_KEY=ck_live_your_key_here

# 监听邮箱地址（必填）
CLAWEMAIL_ADDRESS=your_email@example.com

# 额外 ClawEmail 地址（可选，逗号分隔）
CLAWEMAIL_EXTRA_ADDRESSES=

# ── AgentQQ 配置 ──────────────────────────────
# AgentQQ 额外邮箱地址（可选，逗号分隔）
# 主地址由 agently-cli +me 自动检测
AGENTQQ_EXTRA_ADDRESSES=your_agent@qq.com

# 轮询间隔（秒，默认 60）
AGENTQQ_POLL_INTERVAL_SEC=60

# ── 访客意识 ──────────────────────────────────
# 主账号邮箱（可选，来自此地址的邮件会被特殊处理）
CLAWEMAIL_HOME_EMAIL=

# 访客意识映射（可选）：addr=identity,addr=identity
# 身份用于路由邮件到对应处理规则
# EMAIL_IDENTITY_MAP=ophelia@claw.163.com=ophelia,luoqixi@claw.163.com=luoqixi

# 内部联系人（可选）：发给这些地址的邮件被视为"自己人"，不触发对外意识
# EMAIL_INTERNAL_CONTACTS=trusted@example.com,boss@example.com
